# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///data/scraper.db

# ── Browser ───────────────────────────────────────────────────────────────────
HEADLESS=true
BROWSER_TIMEOUT=30000
# Optional: override user-agent (leave blank to use default)
USER_AGENT=

# ── Rate limiting ─────────────────────────────────────────────────────────────
MIN_DELAY=2.5
MAX_DELAY=6.0
MAX_CONCURRENCY=1

# ── Scraping limits ───────────────────────────────────────────────────────────
MAX_PAGES=20
MAX_LISTINGS=500

# ── Storage ───────────────────────────────────────────────────────────────────
SAVE_RAW=true
RAW_DIR=data/raw
OUTPUT_DIR=data/exports
LOG_DIR=data/logs

# ── Retry ─────────────────────────────────────────────────────────────────────
MAX_RETRIES=3
RETRY_BACKOFF=2.0

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ── Email notifications (optional) ───────────────────────────────────────────
EMAIL_ENABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=
EMAIL_TO=
SMTP_STARTTLS=true
